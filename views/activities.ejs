<%- include('header') %>

<div class="mb-4">
  <a href="/dashboard" class="btn btn-link text-decoration-none p-0 mb-2"><i class="bi bi-arrow-left"></i> Voltar</a>
  <h2>Atividades e Chamada: <%= classInfo.name %></h2>
</div>

<ul class="nav nav-tabs mb-4" id="myTab" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active" id="chamada-tab" data-bs-toggle="tab" data-bs-target="#chamada" type="button" role="tab">Chamada Diária</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="historico-tab" data-bs-toggle="tab" data-bs-target="#historico" type="button" role="tab">Histórico de Chamadas</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="notas-tab" data-bs-toggle="tab" data-bs-target="#notas" type="button" role="tab">Lançar Notas</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="vistos-tab" data-bs-toggle="tab" data-bs-target="#vistos" type="button" role="tab">Lançar Vistos</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="gerenciar-tab" data-bs-toggle="tab" data-bs-target="#gerenciar" type="button" role="tab">Gerenciar Lançamentos</button>
  </li>
</ul>

<div class="tab-content">
  <!-- Aba Chamada -->
  <div class="tab-pane fade show active card p-4" id="chamada">
    <form action="/classes/<%= classInfo.id %>/activities/attendance" method="POST">
      <div class="row mb-3">
        <div class="col-md-3">
          <label class="form-label fw-bold">Data da Aula</label>
          <input type="date" name="date" class="form-control" required value="<%= new Date().toISOString().split('T')[0] %>" max="<%= new Date().toISOString().split('T')[0] %>">
        </div>
        <div class="col-md-3">
          <label class="form-label fw-bold">Quantidade de Aulas</label>
          <select name="lessonCount" id="lessonCountSelect" class="form-select">
            <% for(let i=1; i<=9; i++) { %>
              <option value="<%= i %>" <%= i === 1 ? 'selected' : '' %>><%= i %> <%= i === 1 ? 'Aula' : 'Aulas' %></option>
            <% } %>
          </select>
        </div>
      </div>
      
      <div class="table-responsive">
        <table class="table align-middle" id="attendanceTable">
          <thead>
            <tr>
              <th>Aluno</th>
              <% for(let i=1; i<=9; i++) { %>
                <th class="lesson-column lesson-<%= i %>" <%= i > 1 ? 'style="display:none"' : '' %>><%= i %>ª Aula</th>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% students.forEach(function(s) { %>
              <tr>
                <td class="fw-bold text-nowrap"><%= s.name %></td>
                <% for(let i=1; i<=9; i++) { %>
                  <td class="lesson-column lesson-<%= i %>" <%= i > 1 ? 'style="display:none"' : '' %>>
                    <div class="d-flex flex-column gap-1">
                      <div class="form-check">
                        <input class="form-check-input" type="radio" name="attendance[<%= i %>][sid_<%= s.id %>]" value="Presente" checked>
                        <label class="form-check-label text-success small">Pres.</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="radio" name="attendance[<%= i %>][sid_<%= s.id %>]" value="Ausente">
                        <label class="form-check-label text-danger small">Falta</label>
                      </div>
                    </div>
                  </td>
                <% } %>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <button type="submit" class="btn btn-primary mt-3">Salvar Chamada</button>
    </form>
  </div>

  <!-- Aba Histórico de Chamadas -->
  <div class="tab-pane fade card p-4" id="historico">
    <h4 class="mb-3">Histórico de Chamadas</h4>
    <div class="table-responsive">
      <table class="table table-bordered table-hover text-center align-middle">
        <thead class="table-light">
          <tr>
            <th class="text-start">Aluno</th>
            <% if (attendanceDates && attendanceDates.length > 0) { %>
              <% attendanceDates.forEach(function(date) { %>
                <% 
                  const d = new Date(date + 'T00:00:00'); 
                  const formattedDate = d.toLocaleDateString('pt-BR');
                  const count = lessonsPerDate[date] || 1;
                %>
                <th>
                  <div class="mb-1"><%= formattedDate %></div>
                  <div class="small text-muted mb-2"><%= count %> <%= count === 1 ? 'aula' : 'aulas' %></div>
                  <form action="/classes/<%= classInfo.id %>/activities/attendance/delete" method="POST" onsubmit="return confirm('Excluir toda a chamada deste dia?');">
                    <input type="hidden" name="date" value="<%= date %>">
                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Excluir Chamada"><i class="bi bi-trash"></i></button>
                  </form>
                </th>
              <% }); %>
            <% } else { %>
              <th>Nenhuma chamada registrada</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(function(s) { %>
            <tr>
              <td class="text-start fw-bold text-nowrap"><%= s.name %></td>
              <% if (attendanceDates && attendanceDates.length > 0) { %>
                <% attendanceDates.forEach(function(date) { %>
                  <td>
                    <div class="d-flex justify-content-center gap-1 flex-wrap">
                      <% const count = lessonsPerDate[date] || 1; %>
                      <% for(let l=1; l<=count; l++) { %>
                        <% const status = history[date] && history[date][s.id] ? history[date][s.id][l] : null; %>
                        <span title="<%= l %>ª Aula">
                          <% if (status === 'Presente') { %> 
                            <i class="bi bi-check-circle-fill text-success"></i> 
                          <% } else if (status === 'Ausente') { %> 
                            <i class="bi bi-x-circle-fill text-danger"></i> 
                          <% } else { %> 
                            <span class="text-muted" style="font-size: 0.7rem;">-</span> 
                          <% } %>
                        </span>
                        <% if (l < count) { %><span class="text-muted">|</span><% } %>
                      <% } %>
                    </div>
                  </td>
                <% }); %>
              <% } else { %>
                <td>-</td>
              <% } %>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    document.getElementById('lessonCountSelect').addEventListener('change', function() {
      const count = parseInt(this.value);
      document.querySelectorAll('.lesson-column').forEach(el => {
        el.style.display = 'none';
      });
      for (let i = 1; i <= count; i++) {
        document.querySelectorAll('.lesson-' + i).forEach(el => {
          el.style.display = 'table-cell';
        });
      }
    });
  </script>

  <!-- Aba Notas -->
  <div class="tab-pane fade card p-4" id="notas">
    <form action="/classes/<%= classInfo.id %>/activities/grade" method="POST">
      <input type="hidden" name="type" value="Nota">
      <div class="row mb-4">
        <div class="col-md-6">
          <label class="form-label fw-bold">Tipo de Avaliação</label>
          <select name="activityName" class="form-select" required>
            <option value="Prova (AVI)">Prova (AVI)</option>
            <option value="Atividade Prática">Atividade Prática</option>
            <option value="Participação em Aula">Participação em Aula</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-bold">Data</label>
          <input type="date" name="date" class="form-control" required value="<%= new Date().toISOString().split('T')[0] %>" max="<%= new Date().toISOString().split('T')[0] %>">
        </div>
      </div>
      
      <table class="table">
        <thead>
          <tr>
            <th>Aluno</th>
            <th>Nota (0 a 10)</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(function(s) { %>
            <tr>
              <td class="align-middle"><%= s.name %></td>
              <td>
                <input type="number" step="0.1" max="10" name="grades[sid_<%= s.id %>]" class="form-control w-25" placeholder="Nota">
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      <button type="submit" class="btn btn-success mt-3">Salvar Notas</button>
    </form>
  </div>

  <!-- Aba Vistos -->
  <div class="tab-pane fade card p-4" id="vistos">
    <form action="/classes/<%= classInfo.id %>/activities/grade" method="POST">
      <input type="hidden" name="type" value="Visto">
      <div class="row mb-4">
        <div class="col-md-6">
          <label class="form-label fw-bold">Nome da Atividade / Tarefa</label>
          <input type="text" name="activityName" class="form-control" required placeholder="Ex: Tarefa de Casa Pág. 10">
        </div>
        <div class="col-md-6">
          <label class="form-label fw-bold">Data</label>
          <input type="date" name="date" class="form-control" required value="<%= new Date().toISOString().split('T')[0] %>" max="<%= new Date().toISOString().split('T')[0] %>">
        </div>
      </div>
      
      <table class="table">
        <thead>
          <tr>
            <th>Aluno</th>
            <th>Entregou? (Marcar Visto)</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(function(s) { %>
            <tr>
              <td class="align-middle"><%= s.name %></td>
              <td>
                <div class="form-check mt-2">
                  <input class="form-check-input border-secondary" type="checkbox" name="grades[sid_<%= s.id %>]" value="on" style="transform: scale(1.5);">
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      <button type="submit" class="btn btn-info mt-3 text-white">Salvar Vistos</button>
    </form>
  </div>

  <!-- Aba Gerenciar -->
  <div class="tab-pane fade card p-4" id="gerenciar">
    <h4 class="mb-3">Gerenciar Notas e Vistos</h4>
    <p class="text-muted small">Aqui você pode excluir atividades lançadas incorretamente.</p>
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead class="table-light">
          <tr>
            <th>Data</th>
            <th>Tipo</th>
            <th>Nome da Atividade</th>
            <th class="text-end">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (locals.uniqueGrades && uniqueGrades.length > 0) { %>
            <% uniqueGrades.forEach(function(g) { %>
              <tr>
                <td><%= new Date(g.date + 'T00:00:00').toLocaleDateString('pt-BR') %></td>
                <td>
                  <span class="badge <%= g.type === 'Nota' ? 'bg-primary' : 'bg-info text-white' %>">
                    <%= g.type %>
                  </span>
                </td>
                <td><%= g.activityName %></td>
                <td class="text-end">
                  <form action="/classes/<%= classInfo.id %>/activities/grade/delete" method="POST" class="d-inline" onsubmit="return confirm('Excluir todos os registros desta atividade?');">
                    <input type="hidden" name="activityName" value="<%= g.activityName %>">
                    <input type="hidden" name="type" value="<%= g.type %>">
                    <input type="hidden" name="date" value="<%= g.date %>">
                    <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i> Excluir</button>
                  </form>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="4" class="text-center text-muted">Nenhuma nota ou visto lançado.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('footer') %>
