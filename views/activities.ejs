<%- include('header') %>

<div class="mb-4">
  <a href="/dashboard" class="btn btn-link text-decoration-none p-0 mb-2"><i class="bi bi-arrow-left"></i> Voltar</a>
  <h2>Atividades e Chamada: <%= classInfo.name %></h2>
</div>

<ul class="nav nav-tabs mb-4" id="myTab" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active" id="chamada-tab" data-bs-toggle="tab" data-bs-target="#chamada" type="button" role="tab">Chamada Diária</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="historico-tab" data-bs-toggle="tab" data-bs-target="#historico" type="button" role="tab">Histórico de Chamadas</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="notas-tab" data-bs-toggle="tab" data-bs-target="#notas" type="button" role="tab">Lançar Notas</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="vistos-tab" data-bs-toggle="tab" data-bs-target="#vistos" type="button" role="tab">Lançar Vistos</button>
  </li>
</ul>

<div class="tab-content">
  <!-- Aba Chamada -->
  <div class="tab-pane fade show active card p-4" id="chamada">
    <form action="/classes/<%= classInfo.id %>/activities/attendance" method="POST">
      <div class="mb-3 w-25">
        <label class="form-label fw-bold">Data da Aula</label>
        <input type="date" name="date" class="form-control" required value="<%= new Date().toISOString().split('T')[0] %>" max="<%= new Date().toISOString().split('T')[0] %>">
      </div>
      
      <table class="table align-middle">
        <thead>
          <tr>
            <th>Aluno</th>
            <th>1ª Aula</th>
            <th>2ª Aula</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(function(s) { %>
            <tr>
              <td class="fw-bold"><%= s.name %></td>
              <td>
                <div class="form-check form-check-inline">
                  <input class="form-check-input" type="radio" name="attendance1[sid_<%= s.id %>]" value="Presente" checked>
                  <label class="form-check-label text-success">Pres.</label>
                </div>
                <div class="form-check form-check-inline">
                  <input class="form-check-input" type="radio" name="attendance1[sid_<%= s.id %>]" value="Ausente">
                  <label class="form-check-label text-danger">Falta</label>
                </div>
              </td>
              <td>
                <div class="form-check form-check-inline">
                  <input class="form-check-input" type="radio" name="attendance2[sid_<%= s.id %>]" value="Presente" checked>
                  <label class="form-check-label text-success">Pres.</label>
                </div>
                <div class="form-check form-check-inline">
                  <input class="form-check-input" type="radio" name="attendance2[sid_<%= s.id %>]" value="Ausente">
                  <label class="form-check-label text-danger">Falta</label>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      <button type="submit" class="btn btn-primary mt-3">Salvar Chamada</button>
    </form>
  </div>

  <!-- Aba Histórico de Chamadas -->
  <div class="tab-pane fade card p-4" id="historico">
    <h4 class="mb-3">Histórico de Chamadas</h4>
    <div class="table-responsive">
      <table class="table table-bordered table-hover text-center align-middle">
        <thead class="table-light">
          <tr>
            <th class="text-start">Aluno</th>
            <% if (attendanceDates && attendanceDates.length > 0) { %>
              <% attendanceDates.forEach(function(date) { %>
                <% 
                  const d = new Date(date + 'T00:00:00'); 
                  const formattedDate = d.toLocaleDateString('pt-BR');
                %>
                <th><%= formattedDate %></th>
              <% }); %>
            <% } else { %>
              <th>Nenhuma chamada registrada</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(function(s) { %>
            <tr>
              <td class="text-start fw-bold"><%= s.name %></td>
              <% if (attendanceDates && attendanceDates.length > 0) { %>
                <% attendanceDates.forEach(function(date) { %>
                  <td>
                    <% const a1 = history[date] && history[date][s.id] ? history[date][s.id][1] : null; %>
                    <% const a2 = history[date] && history[date][s.id] ? history[date][s.id][2] : null; %>
                    
                    <% if (a1 === 'Presente') { %> <i class="bi bi-check-circle-fill text-success"></i> <% } else if (a1 === 'Ausente') { %> <i class="bi bi-x-circle-fill text-danger"></i> <% } else { %> - <% } %>
                    /
                    <% if (a2 === 'Presente') { %> <i class="bi bi-check-circle-fill text-success"></i> <% } else if (a2 === 'Ausente') { %> <i class="bi bi-x-circle-fill text-danger"></i> <% } else { %> - <% } %>
                  </td>
                <% }); %>
              <% } else { %>
                <td>-</td>
              <% } %>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Aba Notas -->
  <div class="tab-pane fade card p-4" id="notas">
    <form action="/classes/<%= classInfo.id %>/activities/grade" method="POST">
      <input type="hidden" name="type" value="Nota">
      <div class="row mb-4">
        <div class="col-md-6">
          <label class="form-label fw-bold">Tipo de Avaliação</label>
          <select name="activityName" class="form-select" required>
            <option value="Prova (AVI)">Prova (AVI)</option>
            <option value="Atividade Prática">Atividade Prática</option>
            <option value="Participação em Aula">Participação em Aula</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-bold">Data</label>
          <input type="date" name="date" class="form-control" required value="<%= new Date().toISOString().split('T')[0] %>" max="<%= new Date().toISOString().split('T')[0] %>">
        </div>
      </div>
      
      <table class="table">
        <thead>
          <tr>
            <th>Aluno</th>
            <th>Nota (0 a 10)</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(function(s) { %>
            <tr>
              <td class="align-middle"><%= s.name %></td>
              <td>
                <input type="number" step="0.1" max="10" name="grades[sid_<%= s.id %>]" class="form-control w-25" placeholder="Nota">
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      <button type="submit" class="btn btn-success mt-3">Salvar Notas</button>
    </form>
  </div>

  <!-- Aba Vistos -->
  <div class="tab-pane fade card p-4" id="vistos">
    <form action="/classes/<%= classInfo.id %>/activities/grade" method="POST">
      <input type="hidden" name="type" value="Visto">
      <div class="row mb-4">
        <div class="col-md-6">
          <label class="form-label fw-bold">Nome da Atividade / Tarefa</label>
          <input type="text" name="activityName" class="form-control" required placeholder="Ex: Tarefa de Casa Pág. 10">
        </div>
        <div class="col-md-6">
          <label class="form-label fw-bold">Data</label>
          <input type="date" name="date" class="form-control" required value="<%= new Date().toISOString().split('T')[0] %>" max="<%= new Date().toISOString().split('T')[0] %>">
        </div>
      </div>
      
      <table class="table">
        <thead>
          <tr>
            <th>Aluno</th>
            <th>Entregou? (Marcar Visto)</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(function(s) { %>
            <tr>
              <td class="align-middle"><%= s.name %></td>
              <td>
                <div class="form-check mt-2">
                  <input class="form-check-input border-secondary" type="checkbox" name="grades[sid_<%= s.id %>]" value="on" style="transform: scale(1.5);">
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      <button type="submit" class="btn btn-info mt-3 text-white">Salvar Vistos</button>
    </form>
  </div>
</div>

<%- include('footer') %>
