<%- include('header') %>

<div class="row justify-content-center mt-5">
  <div class="col-md-5">
    <div class="card p-4">
      <div class="text-center mb-4">
        <h2 class="text-primary"><i class="bi bi-mortarboard-fill"></i></h2>
        <h4>Sistema Gestão Escolar</h4>
        <p class="text-muted">Acesse sua conta para continuar</p>
      </div>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form action="/login" method="POST">
        <div class="mb-3">
          <label class="form-label">E-mail</label>
          <input type="email" name="email" class="form-control" required placeholder="admin@escola.com">
        </div>
        <div class="mb-3">
          <label class="form-label">Senha</label>
          <input type="password" name="password" class="form-control" required placeholder="admin123">
        </div>
        <button type="submit" class="btn btn-primary w-100 mb-3">Entrar</button>
        <div class="text-center">
          <span class="text-muted">Não possui conta?</span> <a href="/register" class="text-decoration-none">Cadastre-se</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('footer') %>
